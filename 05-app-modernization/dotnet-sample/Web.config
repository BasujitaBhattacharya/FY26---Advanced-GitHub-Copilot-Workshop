<?xml version="1.0" encoding="utf-8"?>
<!--
  LEGACY: Web.config is .NET Framework only.
  MODERN: In .NET 8, configuration lives in appsettings.json + environment variables.
  The .NET Upgrade Assistant will flag this file and help migrate to appsettings.json.
-->
<configuration>
  <!--
    LEGACY: Connection strings in Web.config — plain text, source-controlled.
    MODERN: Use environment variables, Azure Key Vault, or user-secrets in development.
  -->
  <connectionStrings>
    <add name="DefaultConnection"
         connectionString="Server=(localdb)\MSSQLLocalDB;Database=OntarioPermits;Integrated Security=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <!--
    LEGACY: AppSettings in XML.
    MODERN: Use appsettings.json sections and IConfiguration.GetValue<T>()
  -->
  <appSettings>
    <add key="ApiVersion" value="1.0" />
    <add key="MaxPageSize" value="100" />
    <add key="DefaultRegion" value="Central" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>

  <system.webServer>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>
</configuration>
